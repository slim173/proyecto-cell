@page "/cliente"
@layout CellApp.Components.Layout.BlankLayout
@inject HttpClient Http

<PageTitle>@_empresa.Nombre — Seguimiento de reparación</PageTitle>

<style>
.pg-c *, .pg-c *::before, .pg-c *::after { box-sizing: border-box; margin: 0; padding: 0; }
.pg-c {
    position: fixed; inset: 0; overflow-y: auto; z-index: 9000;
    background: #07090f;
    color: #e2e8f0;
    font-family: 'Segoe UI', system-ui, sans-serif;
    font-size: 1rem; line-height: 1.6;
    scroll-behavior: smooth;
}

/* ── NAVBAR ── */
.c-nav {
    position: sticky; top: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(7,9,15,.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,.06);
}
.c-brand { display: flex; align-items: center; gap: .7rem; text-decoration: none; }
.c-brand-ico {
    width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.15rem;
    box-shadow: 0 0 20px rgba(99,102,241,.5);
}
.c-brand-name { font-size: 1.3rem; font-weight: 800; color: #fff; letter-spacing: -.5px; }
.c-status {
    display: flex; align-items: center; gap: .5rem;
    background: rgba(34,197,94,.08); border: 1px solid rgba(34,197,94,.2);
    color: #4ade80; border-radius: 99px; padding: .35rem 1rem;
    font-size: .78rem; font-weight: 700;
}
.c-status-dot {
    width: 8px; height: 8px; border-radius: 50%; background: #4ade80;
    animation: s-pulse 2s ease-in-out infinite;
}
@@keyframes s-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }

/* ── HERO ── */
.c-hero {
    position: relative; overflow: hidden;
    min-height: 92vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem 6rem;
    background: radial-gradient(ellipse 120% 80% at 50% -20%, rgba(99,102,241,.35) 0%, transparent 60%),
                radial-gradient(ellipse 80% 60% at 80% 100%, rgba(168,85,247,.2) 0%, transparent 55%),
                linear-gradient(180deg, #0d0f1f 0%, #07090f 100%);
}
.c-hero-grid {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
    background-image:
        linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 0%, transparent 100%);
}
.c-hero-glow {
    position: absolute; pointer-events: none; border-radius: 50%; filter: blur(80px);
}
.g1 { width:500px;height:500px;background:rgba(99,102,241,.15);  top:-200px; left:-100px; }
.g2 { width:400px;height:400px;background:rgba(168,85,247,.12);  bottom:-100px; right:-80px; }
.g3 { width:300px;height:300px;background:rgba(236,72,153,.08);  top:40%;left:60%; }

.c-hero-inner { position: relative; z-index: 1; max-width: 780px; width: 100%; }

.c-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(99,102,241,.1); border: 1px solid rgba(99,102,241,.3);
    color: #a5b4fc; border-radius: 99px;
    padding: .45rem 1.2rem; font-size: .8rem; font-weight: 700;
    letter-spacing: .04em; margin-bottom: 1.75rem;
    text-transform: uppercase;
}
.c-tag i { font-size: .7rem; }

.c-hero h1 {
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 900; color: #fff;
    line-height: 1.05; letter-spacing: -2.5px;
    margin-bottom: 1.25rem;
}
.c-hero h1 .c-hi {
    background: linear-gradient(135deg, #818cf8 0%, #c084fc 50%, #f472b6 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.c-hero-sub {
    color: #64748b; font-size: 1.1rem; line-height: 1.8;
    max-width: 520px; margin: 0 auto 2.5rem;
}

/* ── BUSCADOR EN HERO ── */
.c-search {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 1.5rem;
    padding: 1.75rem 2rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 32px 80px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.08);
    max-width: 580px; margin: 0 auto;
}
.c-search-lbl {
    font-size: .72rem; font-weight: 800; letter-spacing: .12em;
    text-transform: uppercase; color: #475569; margin-bottom: .75rem;
    display: flex; align-items: center; gap: .5rem;
}
.c-search-lbl::before, .c-search-lbl::after {
    content: ''; flex: 1; height: 1px; background: rgba(255,255,255,.06);
}
.c-search-row { display: flex; gap: .5rem; }
.c-search-inp {
    flex: 1; min-width: 0;
    background: rgba(255,255,255,.06);
    border: 1.5px solid rgba(255,255,255,.1);
    border-radius: 1rem; color: #f8fafc;
    font-family: 'Courier New', monospace;
    font-size: 1.05rem; letter-spacing: .05em;
    padding: .85rem 1.25rem; outline: none;
    transition: all .2s;
}
.c-search-inp::placeholder { color: rgba(255,255,255,.18); }
.c-search-inp:focus {
    border-color: #6366f1;
    background: rgba(99,102,241,.08);
    box-shadow: 0 0 0 4px rgba(99,102,241,.15);
}
.c-search-btn {
    flex-shrink: 0; border: none; border-radius: 1rem; cursor: pointer;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    color: #fff; font-weight: 800; font-size: .95rem;
    padding: .85rem 1.5rem;
    display: flex; align-items: center; gap: .55rem;
    box-shadow: 0 8px 24px rgba(99,102,241,.5);
    transition: all .2s; white-space: nowrap;
}
.c-search-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 12px 32px rgba(99,102,241,.6); }
.c-search-btn:active:not(:disabled) { transform: translateY(0); }
.c-search-btn:disabled { opacity: .5; cursor: not-allowed; }
.c-warn {
    margin-top: 1rem;
    background: rgba(239,68,68,.08); border: 1px solid rgba(239,68,68,.2);
    border-radius: .85rem; color: #fca5a5;
    padding: .75rem 1rem; font-size: .88rem;
    display: flex; align-items: center; gap: .6rem;
}

/* Trucos de confianza bajo el buscador */
.c-trust {
    display: flex; gap: 1.5rem; justify-content: center;
    flex-wrap: wrap; margin-top: 1.5rem;
}
.c-trust-item {
    display: flex; align-items: center; gap: .4rem;
    color: #475569; font-size: .8rem; font-weight: 600;
}
.c-trust-item i { color: #6366f1; }

/* ── RESULTADO ── */
.c-result-wrap { max-width: 700px; margin: 3rem auto; padding: 0 1rem; }
.c-result {
    border-radius: 1.5rem; overflow: hidden;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
    box-shadow: 0 32px 80px rgba(0,0,0,.6);
    animation: c-in .4s cubic-bezier(.22,1,.36,1);
}
@@keyframes c-in { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:none} }

/* Cabecera resultado */
.c-res-head {
    padding: 1.75rem 2rem;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
    position: relative; overflow: hidden;
}
.c-res-head::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(135deg, rgba(99,102,241,.12) 0%, rgba(168,85,247,.08) 100%);
}
.c-res-order { font-family: 'Courier New', monospace; font-size: 1.5rem; font-weight: 900; color: #fff; position: relative; }
.c-res-device { color: #64748b; font-size: .88rem; margin-top: .2rem; position: relative; }
.c-res-device i { color: #6366f1; margin-right: .3rem; }

/* Badge estado */
.c-badge {
    position: relative; z-index: 1;
    display: inline-flex; align-items: center; gap: .5rem;
    border-radius: 99px; padding: .5rem 1.2rem;
    font-size: .85rem; font-weight: 800;
    border: 1px solid transparent;
}
.b-recibido     { background:rgba(100,116,139,.12); border-color:rgba(100,116,139,.3); color:#94a3b8; }
.b-diagnosticado{ background:rgba(59,130,246,.12);  border-color:rgba(59,130,246,.3);  color:#60a5fa; }
.b-en_reparacion{ background:rgba(234,179,8,.12);   border-color:rgba(234,179,8,.3);   color:#fbbf24; }
.b-reparado     { background:rgba(16,185,129,.12);  border-color:rgba(16,185,129,.3);  color:#34d399; }
.b-entregado    { background:rgba(34,197,94,.12);   border-color:rgba(34,197,94,.3);   color:#4ade80; }
.b-no_reparable { background:rgba(239,68,68,.12);   border-color:rgba(239,68,68,.3);   color:#f87171; }

/* Timeline vertical */
.c-timeline { padding: 1.75rem 2rem; border-bottom: 1px solid rgba(255,255,255,.06); }
.c-tl-track { position: relative; display: flex; flex-direction: column; gap: 0; }
.c-tl-item { display: flex; gap: 1rem; position: relative; }
.c-tl-left { display: flex; flex-direction: column; align-items: center; width: 36px; flex-shrink: 0; }
.c-tl-circ {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: .8rem;
    border: 2px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.04); color: rgba(255,255,255,.2);
    transition: all .3s;
}
.c-tl-line {
    width: 2px; flex: 1; min-height: 20px;
    background: rgba(255,255,255,.06); margin: 3px 0;
}
.c-tl-item:last-child .c-tl-line { display: none; }
.c-tl-body { padding: .4rem 0 1.25rem; flex: 1; }
.c-tl-body:last-child { padding-bottom: 0; }
.c-tl-name { font-size: .9rem; font-weight: 600; color: rgba(255,255,255,.3); }
.c-tl-desc { font-size: .78rem; color: rgba(255,255,255,.2); margin-top: .1rem; }

.c-tl-item.tl-done .c-tl-circ { background: rgba(16,185,129,.2); border-color: #10b981; color: #34d399; box-shadow: 0 0 12px rgba(16,185,129,.3); }
.c-tl-item.tl-done .c-tl-line  { background: rgba(16,185,129,.25); }
.c-tl-item.tl-done .c-tl-name  { color: #34d399; }
.c-tl-item.tl-active .c-tl-circ {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    border-color: transparent; color: #fff;
    box-shadow: 0 0 0 4px rgba(99,102,241,.2), 0 0 20px rgba(99,102,241,.5);
    animation: tl-glow 2s ease-in-out infinite;
}
.c-tl-item.tl-active .c-tl-name { color: #a5b4fc; font-weight: 700; }
.c-tl-item.tl-active .c-tl-desc { color: #818cf8; }
@@keyframes tl-glow {
    0%,100%{ box-shadow:0 0 0 4px rgba(99,102,241,.2),0 0 20px rgba(99,102,241,.5); }
    50%    { box-shadow:0 0 0 8px rgba(99,102,241,.1),0 0 32px rgba(99,102,241,.7); }
}

.c-no-rep {
    margin: 1.5rem 2rem;
    background: rgba(239,68,68,.07); border: 1px solid rgba(239,68,68,.2);
    border-radius: 1rem; color: #f87171; padding: 1.25rem 1.5rem;
    display: flex; align-items: center; gap: .85rem;
}

/* Datos info */
.c-res-info { padding: 1.25rem 2rem; }
.c-info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: .8rem 0; border-bottom: 1px solid rgba(255,255,255,.04);
}
.c-info-row:last-child { border-bottom: none; }
.c-info-label { color: #475569; font-size: .88rem; display: flex; align-items: center; gap: .6rem; }
.c-info-label i { color: #6366f1; width: 14px; text-align: center; }
.c-info-val { color: #e2e8f0; font-weight: 600; font-size: .93rem; }
.c-info-val.total { color: #4ade80; font-size: 1.5rem; font-weight: 900; }

.c-res-foot {
    background: rgba(99,102,241,.05); border-top: 1px solid rgba(99,102,241,.1);
    padding: 1rem 2rem; text-align: center; color: #334155; font-size: .82rem;
    display: flex; align-items: center; justify-content: center; gap: .5rem;
}
.c-res-foot i { color: #6366f1; }

/* ── SECCIÓN PRINCIPAL ── */
.c-sections { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem 5rem; }

/* Stats */
.c-stats {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 1px;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 1.25rem; overflow: hidden; margin-bottom: 5rem;
}
.c-stat { background: rgba(255,255,255,.02); padding: 2rem 1rem; text-align: center; }
.c-stat-n {
    font-size: 2.2rem; font-weight: 900; line-height: 1;
    background: linear-gradient(135deg, #818cf8, #c084fc);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin-bottom: .4rem;
}
.c-stat-l { color: #475569; font-size: .78rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }

/* Sección header */
.c-sh { text-align: center; margin-bottom: 3rem; }
.c-sh h2 { font-size: clamp(1.6rem,3vw,2.4rem); font-weight: 900; color: #fff; letter-spacing: -.5px; margin-bottom: .5rem; }
.c-sh h2 em {
    font-style: normal;
    background: linear-gradient(135deg, #818cf8, #c084fc);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.c-sh p { color: #475569; font-size: .95rem; }

/* Servicios */
.c-svcs { display: grid; grid-template-columns: repeat(auto-fit,minmax(180px,1fr)); gap: 1rem; margin-bottom: 5rem; }
.c-svc {
    background: rgba(255,255,255,.02);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 1.25rem; padding: 1.75rem 1.25rem;
    text-align: center; cursor: default;
    transition: all .25s cubic-bezier(.22,1,.36,1);
}
.c-svc:hover {
    background: rgba(99,102,241,.06); border-color: rgba(99,102,241,.3);
    transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,.4);
}
.c-svc-i {
    width: 58px; height: 58px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; margin: 0 auto 1.1rem;
}
.si1{background:rgba(99,102,241,.15);color:#818cf8}
.si2{background:rgba(34,197,94,.12); color:#4ade80}
.si3{background:rgba(34,211,238,.12);color:#22d3ee}
.si4{background:rgba(168,85,247,.15);color:#c084fc}
.si5{background:rgba(249,115,22,.12);color:#fb923c}
.si6{background:rgba(236,72,153,.12);color:#f472b6}
.c-svc h6 { color:#f1f5f9; font-weight:800; font-size:.95rem; margin-bottom:.4rem; }
.c-svc p  { color:#475569; font-size:.8rem; line-height:1.6; }

/* Promo */
.c-promo {
    background: linear-gradient(135deg, rgba(99,102,241,.15) 0%, rgba(168,85,247,.12) 100%);
    border: 1px solid rgba(99,102,241,.25); border-radius: 1.5rem;
    padding: 2.5rem; display: flex; align-items: center; gap: 2rem;
    flex-wrap: wrap; margin-bottom: 5rem; position: relative; overflow: hidden;
}
.c-promo::after {
    content:''; position:absolute; top:-80px; right:-80px;
    width:300px; height:300px; border-radius:50%;
    background:radial-gradient(circle,rgba(168,85,247,.15),transparent 65%); pointer-events:none;
}
.c-promo-icon { font-size:3.5rem; line-height:1; flex-shrink:0; }
.c-promo-body { flex:1; min-width:200px; }
.c-promo-body h3 { color:#fff; font-weight:900; font-size:1.35rem; margin-bottom:.4rem; }
.c-promo-body p  { color:#94a3b8; font-size:.9rem; }
.c-promo-pill {
    position: relative; z-index: 1;
    background: linear-gradient(135deg,#6366f1,#a855f7);
    color:#fff; font-weight:900; font-size:1rem; padding:.85rem 1.75rem;
    border-radius:1rem; flex-shrink:0;
    box-shadow: 0 8px 28px rgba(99,102,241,.5);
}

/* Por qué */
.c-why { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1rem; margin-bottom:5rem; }
.c-why-c {
    background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.06);
    border-radius:1.25rem; padding:1.75rem;
    display:flex; gap:1rem; align-items:flex-start;
}
.c-why-n {
    font-size:2.2rem; font-weight:900; line-height:1; flex-shrink:0;
    background:linear-gradient(135deg,#818cf8,#c084fc);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.c-why-c h6 { color:#f1f5f9; font-weight:800; margin-bottom:.35rem; font-size:.95rem; }
.c-why-c p  { color:#475569; font-size:.82rem; line-height:1.6; }

/* ── FOOTER ── */
.c-footer {
    background: rgba(0,0,0,.3);
    border-top: 1px solid rgba(255,255,255,.05);
    padding: 3rem 2rem 2rem; text-align: center;
}
.c-f-logo { font-size:1.6rem; font-weight:900; color:#fff; margin-bottom:.4rem; }
.c-f-logo em { font-style:normal; color:#a855f7; }
.c-f-sub  { color:#1e293b; font-size:.88rem; margin-bottom:1.5rem; }
.c-f-links { display:flex; gap:2rem; justify-content:center; flex-wrap:wrap; margin-bottom:1.5rem; }
.c-f-links a { color:#334155; text-decoration:none; font-size:.85rem; display:inline-flex; align-items:center; gap:.4rem; transition:color .15s; }
.c-f-links a:hover { color:#818cf8; }
.c-f-copy { color:#1e293b; font-size:.77rem; }
.c-f-copy span { color:#6366f1; }

/* ── WHATSAPP FLOTANTE ── */
.c-wa {
    position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 9100;
    width: 58px; height: 58px; border-radius: 50%;
    background: #25d366; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; text-decoration: none;
    box-shadow: 0 8px 28px rgba(37,211,102,.5);
    transition: all .2s;
    animation: wa-in .5s cubic-bezier(.22,1,.36,1) 1s both;
}
.c-wa:hover { transform: scale(1.1); box-shadow: 0 12px 36px rgba(37,211,102,.7); }
@@keyframes wa-in { from{opacity:0;transform:scale(.5)} to{opacity:1;transform:scale(1)} }

/* ── RESPONSIVE ── */
@@media (max-width:640px) {
    .c-nav { padding: .85rem 1rem; }
    .c-hero { padding: 3rem 1rem 5rem; min-height: auto; }
    .c-hero h1 { letter-spacing:-1px; }
    .c-search { padding: 1.25rem; }
    .c-search-row { flex-direction: column; }
    .c-search-btn { justify-content: center; }
    .c-stats { grid-template-columns: repeat(2,1fr); }
    .c-result-wrap { padding: 0 .75rem; }
    .c-res-head, .c-res-info, .c-timeline { padding: 1.25rem 1rem; }
    .c-res-head { flex-direction: column; align-items: flex-start; }
    .c-timeline { padding: 1.25rem 1rem; }
    .c-sections { padding: 0 1rem 4rem; }
    .c-promo { flex-direction: column; text-align: center; }
    .c-promo-pill { width: 100%; text-align: center; }
    .c-trust { gap: 1rem; }
    .c-no-rep { margin: 1rem; }
}
</style>

<div class="pg-c">

<!-- NAV -->
<nav class="c-nav">
    <a class="c-brand" href="/cliente">
        <div class="c-brand-ico"><i class="fas fa-stethoscope"></i></div>
        <div class="c-brand-name">@_empresa.Nombre</div>
    </a>
    <div class="c-status">
        <span class="c-status-dot"></span>
        Abierto ahora
    </div>
</nav>

<!-- HERO + BUSCADOR -->
<section class="c-hero">
    <div class="c-hero-grid"></div>
    <div class="c-hero-glow g1"></div>
    <div class="c-hero-glow g2"></div>
    <div class="c-hero-glow g3"></div>

    <div class="c-hero-inner">
        <div class="c-tag">
            <i class="fas fa-satellite-dish"></i>
            Seguimiento en tiempo real
        </div>

        <h1>
            ¿Cómo va<br />tu <span class="c-hi">reparación?</span>
        </h1>
        <p class="c-hero-sub">
            Introduce tu número de orden y consulta el estado actualizado de tu dispositivo al instante.
        </p>

        <!-- BUSCADOR -->
        <div class="c-search">
            <div class="c-search-lbl">número de orden</div>
            <div class="c-search-row">
                <input class="c-search-inp"
                       placeholder="Ej: REP/2024/001"
                       @bind="_numero"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       autocomplete="off"
                       spellcheck="false" />
                <button class="c-search-btn" @onclick="BuscarAsync" disabled="@_buscando">
                    @if (_buscando)
                    {
                        <span class="spinner-border spinner-border-sm" style="width:.9rem;height:.9rem;border-width:2px"></span>
                    }
                    else
                    {
                        <i class="fas fa-search"></i>
                    }
                    <span>Consultar</span>
                </button>
            </div>
            @if (_error != null)
            {
                <div class="c-warn">
                    <i class="fas fa-exclamation-circle"></i> @_error
                </div>
            }
        </div>

        <div class="c-trust">
            <span class="c-trust-item"><i class="fas fa-lock"></i> Consulta segura y privada</span>
            <span class="c-trust-item"><i class="fas fa-bolt"></i> Actualización en tiempo real</span>
            <span class="c-trust-item"><i class="fas fa-shield-alt"></i> Garantía incluida</span>
        </div>
    </div>
</section>

<!-- RESULTADO -->
@if (_resultado != null)
{
    <div class="c-result-wrap">
        <div class="c-result">

            <!-- Cabecera -->
            <div class="c-res-head">
                <div>
                    <div class="c-res-order">@_resultado.NumeroOrden</div>
                    <div class="c-res-device"><i class="fas fa-mobile-alt"></i>@_resultado.Dispositivo</div>
                </div>
                <span class="c-badge b-@_resultado.Estado">
                    <i class="@IconoEstado(_resultado.Estado)"></i>
                    @_resultado.EstadoLabel
                </span>
            </div>

            <!-- Timeline vertical -->
            @if (_resultado.Estado != "no_reparable")
            {
                <div class="c-timeline">
                    <div class="c-tl-track">
                        @for (int i = 0; i < _pasosLabel.Length; i++)
                        {
                            var idx   = i;
                            var label = _pasosLabel[idx];
                            var desc  = _pasosDesc[idx];
                            var icon  = _pasosIcon[idx];
                            var cls   = idx < _resultado.PasoActual  ? "tl-done"
                                      : idx == _resultado.PasoActual ? "tl-active" : "";
                            <div class="c-tl-item @cls">
                                <div class="c-tl-left">
                                    <div class="c-tl-circ">
                                        @if (idx < _resultado.PasoActual)
                                        { <i class="fas fa-check"></i> }
                                        else
                                        { <i class="@icon"></i> }
                                    </div>
                                    <div class="c-tl-line"></div>
                                </div>
                                <div class="c-tl-body">
                                    <div class="c-tl-name">@label</div>
                                    <div class="c-tl-desc">@desc</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="c-no-rep">
                    <i class="fas fa-times-circle fa-lg"></i>
                    <div><strong>Equipo no reparable.</strong> Pásate por la tienda para más información.</div>
                </div>
            }

            <!-- Datos -->
            <div class="c-res-info">
                @if (_resultado.FechaRecepcion.HasValue)
                {
                    <div class="c-info-row">
                        <span class="c-info-label"><i class="fas fa-calendar-plus"></i>Fecha de entrada</span>
                        <span class="c-info-val">@_resultado.FechaRecepcion.Value.ToString("dd/MM/yyyy")</span>
                    </div>
                }
                @if (_resultado.FechaEntrega.HasValue)
                {
                    <div class="c-info-row">
                        <span class="c-info-label"><i class="fas fa-calendar-check"></i>Entrega estimada</span>
                        <span class="c-info-val">@_resultado.FechaEntrega.Value.ToString("dd/MM/yyyy")</span>
                    </div>
                }
                @if (_resultado.FechaEntregaReal.HasValue)
                {
                    <div class="c-info-row">
                        <span class="c-info-label"><i class="fas fa-handshake"></i>Entregado el</span>
                        <span class="c-info-val">@_resultado.FechaEntregaReal.Value.ToString("dd/MM/yyyy")</span>
                    </div>
                }
                @if (_resultado.Presupuesto.HasValue)
                {
                    <div class="c-info-row">
                        <span class="c-info-label"><i class="fas fa-file-invoice-dollar"></i>Presupuesto</span>
                        <span class="c-info-val">@_resultado.Presupuesto.Value.ToString("N2") €</span>
                    </div>
                }
                @if (_resultado.Total.HasValue)
                {
                    <div class="c-info-row">
                        <span class="c-info-label"><i class="fas fa-receipt"></i>Total reparación</span>
                        <span class="c-info-val total">@_resultado.Total.Value.ToString("N2") €</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_resultado.Solucion))
                {
                    <div class="c-info-row" style="flex-direction:column;align-items:flex-start;gap:.4rem">
                        <span class="c-info-label"><i class="fas fa-tools"></i>Solución aplicada</span>
                        <span class="c-info-val">@_resultado.Solucion</span>
                    </div>
                }
            </div>

            <div class="c-res-foot">
                <i class="fas fa-shield-alt"></i>
                Garantía de 3 meses en mano de obra y piezas
            </div>
        </div>
    </div>
}

