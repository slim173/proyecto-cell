@code {
    string  _numero = string.Empty;
    bool    _buscando;
    string? _error;
    SeguimientoDto?   _resultado;
    EmpresaPublicaDto _empresa = new();

    readonly string[] _pasosLabel = { "Recibido",  "Diagnosticado",       "En reparación",         "Reparado",                    "Entregado"             };
    readonly string[] _pasosDesc  = { "Equipo en tienda", "Revisión completada", "Técnico trabajando en tu equipo", "Listo para recoger",  "Equipo entregado al cliente" };
    readonly string[] _pasosIcon  = { "fas fa-inbox", "fas fa-stethoscope", "fas fa-wrench", "fas fa-check-circle", "fas fa-handshake" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var resp = await Http.GetFromJsonAsync<ApiWrapEmpresa>("api/configuracion/empresa-publica", opts);
            if (resp?.Success == true && resp.Data != null)
                _empresa = resp.Data;
        }
        catch { }
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await BuscarAsync();
    }

    async Task BuscarAsync()
    {
        var n = _numero.Trim().ToUpper();
        if (string.IsNullOrWhiteSpace(n)) { _error = "Introduce el número de orden."; return; }
        _error = null; _resultado = null; _buscando = true;
        StateHasChanged();
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var resp = await Http.GetFromJsonAsync<ApiWrap>(
                $"api/reparaciones/seguimiento?numero={Uri.EscapeDataString(n)}", opts);
            if (resp?.Success == true && resp.Data != null) _resultado = resp.Data;
            else _error = "No se encontró ninguna orden con ese número.";
        }
        catch { _error = "No se encontró la orden. Comprueba el número e inténtalo de nuevo."; }
        finally { _buscando = false; }
    }

    static string IconoEstado(string? e) => e switch
    {
        "entregado"     => "fas fa-handshake",
        "reparado"      => "fas fa-check-circle",
        "en_reparacion" => "fas fa-wrench",
        "diagnosticado" => "fas fa-stethoscope",
        "no_reparable"  => "fas fa-times-circle",
        _               => "fas fa-clock"
    };

    sealed class EmpresaPublicaDto
    {
        public string Nombre   { get; set; } = "Mi Tienda";
        public string Telefono { get; set; } = "";
        public string Email    { get; set; } = "";
        public string Web      { get; set; } = "";
        public string Ciudad   { get; set; } = "";
        public string LogoUrl  { get; set; } = "";
    }

    sealed class SeguimientoDto
    {
        public string    NumeroOrden      { get; set; } = "";
        public string    Dispositivo      { get; set; } = "";
        public string    Estado           { get; set; } = "";
        public string    EstadoLabel      { get; set; } = "";
        public int       PasoActual       { get; set; }
        public DateTime? FechaRecepcion   { get; set; }
        public DateTime? FechaEntrega     { get; set; }
        public DateTime? FechaEntregaReal { get; set; }
        public decimal?  Presupuesto      { get; set; }
        public decimal?  Total            { get; set; }
        public string?   Solucion         { get; set; }
    }

    sealed class ApiWrap        { public bool Success { get; set; } public SeguimientoDto?    Data { get; set; } }
    sealed class ApiWrapEmpresa { public bool Success { get; set; } public EmpresaPublicaDto? Data { get; set; } }
}
