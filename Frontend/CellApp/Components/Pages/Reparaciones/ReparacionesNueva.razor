@page "/reparaciones/nueva"
@rendermode InteractiveServer
@inject ReparacionApiService ReparaSvc
@inject ClienteApiService ClienteSvc
@inject NavigationManager Nav
@inject NotificacionService Notif

<PageTitle>Nueva reparación — CellShop</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="fas fa-tools me-2 text-primary"></i>Nueva orden de reparación</h4>
    <a href="/reparaciones" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="row g-3">
                    <!-- Cliente -->
                    <div class="col-12">
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">
                            <i class="fas fa-user me-1"></i>Cliente
                        </h6>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Cliente <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_dto.ClienteId">
                            <option value="0">— Seleccionar cliente —</option>
                            @foreach (var c in _clientes)
                            {
                                <option value="@c.Id">@c.NombreCompleto — @c.Email</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Prioridad</label>
                        <select class="form-select" @bind="_dto.Prioridad">
                            <option value="baja">Baja</option>
                            <option value="normal" selected>Normal</option>
                            <option value="alta">Alta</option>
                            <option value="urgente">Urgente</option>
                        </select>
                    </div>

                    <!-- Dispositivo -->
                    <div class="col-12 mt-2">
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">
                            <i class="fas fa-mobile-alt me-1"></i>Dispositivo
                        </h6>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Tipo <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_dto.Dispositivo">
                            <option value="">— Seleccionar —</option>
                            <option value="Smartphone">Smartphone</option>
                            <option value="Tablet">Tablet</option>
                            <option value="Portátil">Portátil</option>
                            <option value="Smartwatch">Smartwatch</option>
                            <option value="Consola">Consola</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Marca</label>
                        <input class="form-control" placeholder="Samsung, Apple, Xiaomi..." @bind="_dto.Marca" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Modelo</label>
                        <input class="form-control" placeholder="Galaxy S24, iPhone 15..." @bind="_dto.Modelo" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">IMEI / Número de serie</label>
                        <input class="form-control" placeholder="IMEI o S/N (opcional)" @bind="_dto.Imei" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Técnico asignado</label>
                        <input class="form-control" placeholder="Nombre del técnico" @bind="_dto.TecnicoAsignado" />
                    </div>

                    <!-- Falla -->
                    <div class="col-12 mt-2">
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">
                            <i class="fas fa-exclamation-triangle me-1"></i>Descripción del problema
                        </h6>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Descripción de la falla <span class="text-danger">*</span></label>
                        <textarea class="form-control" rows="3"
                                  placeholder="Describe el problema reportado por el cliente..."
                                  @bind="_dto.DescripcionFalla"></textarea>
                    </div>

                    <!-- Precio y fecha -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Precio estimado (€)</label>
                        <div class="input-group">
                            <input class="form-control" type="number" step="0.01" min="0"
                                   placeholder="0.00" @bind="_dto.PrecioEstimado" />
                            <span class="input-group-text">€</span>
                        </div>
                        <small class="text-muted">Sin IVA</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Fecha estimada de entrega</label>
                        <input class="form-control" type="date" @bind="_fechaEstimada" />
                    </div>
                </div>

                <div class="alert alert-info mt-4 mb-0 py-2 small">
                    <i class="fas fa-camera me-2"></i>
                    Las fotografías del dispositivo se añaden desde la ficha de la orden, una vez registrada.
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger mt-3">
                        <i class="fas fa-times-circle me-2"></i>@_error
                    </div>
                }

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a href="/reparaciones" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Cancelar
                    </a>
                    <button class="btn btn-primary" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="fas fa-save me-1"></i>Registrar orden
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    CreateReparacionDto _dto = new() { Prioridad = "normal" };
    List<ClienteDto> _clientes = new();
    DateTime? _fechaEstimada;
    bool _guardando;
    string _error = string.Empty;

    [SupplyParameterFromQuery] public int? ClienteId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _clientes = await ClienteSvc.GetAllAsync();
        if (ClienteId.HasValue) _dto.ClienteId = ClienteId.Value;
    }

    async Task Guardar()
    {
        _error = string.Empty;
        if (_dto.ClienteId == 0) { _error = "Selecciona un cliente."; return; }
        if (string.IsNullOrWhiteSpace(_dto.Dispositivo)) { _error = "Selecciona el tipo de dispositivo."; return; }
        if (string.IsNullOrWhiteSpace(_dto.DescripcionFalla)) { _error = "Describe la falla del dispositivo."; return; }

        _dto.FechaEstimadaEntrega = _fechaEstimada;
        _guardando = true;
        try
        {
            var (ok, msg, data) = await ReparaSvc.CreateAsync(_dto);
            if (!ok) { _error = msg; return; }

            Notif.Success("Orden de reparación registrada correctamente.");
            // Navigate to detail page with auto-print flag
            Nav.NavigateTo($"/reparaciones/{data!.Id}?autoImprimir=1");
        }
        catch (Exception ex)
        {
            _error = "Error al registrar la orden: " + ex.Message;
        }
        finally { _guardando = false; }
    }
}
