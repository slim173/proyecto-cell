@page "/facturas/nueva"
@rendermode InteractiveServer
@inject FacturaApiService Svc
@inject ClienteApiService ClienteSvc
@inject NotificacionService Notif
@inject NavigationManager Nav

<PageTitle>Nueva factura — CellShop</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="fas fa-file-invoice me-2 text-primary"></i>Nueva factura manual</h4>
    <a href="/facturas" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row g-3">

    <!-- Columna izquierda: datos principales + líneas -->
    <div class="col-lg-8">

        <!-- Datos de cabecera -->
        <div class="card shadow-sm mb-3">
            <div class="card-header"><i class="fas fa-info-circle me-2 text-primary"></i>Datos de la factura</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-7">
                        <label class="form-label">Cliente <span class="text-danger">*</span></label>
                        <select class="form-select @(_validado && _dto.ClienteId == 0 ? "is-invalid" : "")"
                                @bind="_dto.ClienteId">
                            <option value="0">— Selecciona un cliente —</option>
                            @foreach (var c in _clientes)
                            {
                                <option value="@c.Id">@c.NombreCompleto @(!string.IsNullOrEmpty(c.Nif) ? $"({c.Nif})" : "")</option>
                            }
                        </select>
                        @if (_validado && _dto.ClienteId == 0)
                        {
                            <div class="invalid-feedback">Selecciona un cliente.</div>
                        }
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Fecha de emisión <span class="text-danger">*</span></label>
                        <input class="form-control" type="date"
                               value="@_dto.FechaEmision.ToString("yyyy-MM-dd")"
                               @onchange="e => _dto.FechaEmision = DateTime.Parse(e.Value!.ToString()!)" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Líneas de factura -->
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-list me-2 text-primary"></i>Líneas de la factura</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="AgregarLinea">
                    <i class="fas fa-plus me-1"></i>Añadir línea
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="min-width:220px">Descripción</th>
                                <th style="width:90px" class="text-center">Cant.</th>
                                <th style="width:130px" class="text-end">Precio unit.</th>
                                <th style="width:120px" class="text-end">Subtotal</th>
                                <th style="width:42px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < _dto.Lineas.Count; i++)
                            {
                                var idx = i;
                                var linea = _dto.Lineas[idx];
                                <tr>
                                    <td>
                                        <input class="form-control form-control-sm @(_validado && string.IsNullOrWhiteSpace(linea.Descripcion) ? "is-invalid" : "")"
                                               placeholder="Descripción del servicio o producto"
                                               @bind="linea.Descripcion" />
                                    </td>
                                    <td>
                                        <input class="form-control form-control-sm text-center @(_validado && linea.Cantidad <= 0 ? "is-invalid" : "")"
                                               type="number" min="1"
                                               @bind="linea.Cantidad" />
                                    </td>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <input class="form-control text-end @(_validado && linea.PrecioUnitario <= 0 ? "is-invalid" : "")"
                                                   type="number" min="0.01" step="0.01"
                                                   @bind="linea.PrecioUnitario" />
                                            <span class="input-group-text">€</span>
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold" style="color:#818cf8">
                                        @linea.Subtotal.ToString("N2") €
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => EliminarLinea(idx)"
                                                disabled="@(_dto.Lineas.Count == 1)">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_validado && _dto.Lineas.Count == 0)
                {
                    <div class="alert alert-danger m-3 py-2 small">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        Añade al menos una línea a la factura.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Columna derecha: resumen y envío -->
    <div class="col-lg-4">
        <div class="card shadow-sm" style="position:sticky;top:70px">
            <div class="card-header"><i class="fas fa-calculator me-2 text-primary"></i>Resumen</div>
            <div class="card-body">

                <!-- Totales calculados -->
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Base imponible</span>
                    <span class="fw-semibold">@BaseImponible.ToString("N2") €</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">IVA (21%)</span>
                    <span class="fw-semibold">@ImporteIva.ToString("N2") €</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-700">TOTAL</span>
                    <span class="fw-800 fs-5" style="color:#818cf8">@Total.ToString("N2") €</span>
                </div>

                <!-- Info cliente seleccionado -->
                @if (_clienteSeleccionado != null)
                {
                    <div class="p-2 rounded mb-3" style="background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.2)">
                        <div class="fw-semibold small">@_clienteSeleccionado.NombreCompleto</div>
                        @if (!string.IsNullOrEmpty(_clienteSeleccionado.Nif))
                        {
                            <div class="small text-muted">NIF: @_clienteSeleccionado.Nif</div>
                        }
                        @if (!string.IsNullOrEmpty(_clienteSeleccionado.Email))
                        {
                            <div class="small text-muted"><i class="fas fa-envelope me-1 opacity-50"></i>@_clienteSeleccionado.Email</div>
                        }
                    </div>
                }

                <!-- Botón crear -->
                <button class="btn btn-primary w-100" @onclick="Guardar" disabled="@_guardando">
                    @if (_guardando)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="fas fa-file-invoice me-2"></i>Crear factura y generar PDF
                </button>

                <p class="text-muted small mt-2 text-center mb-0">
                    Se asignará el siguiente número de factura correlativo.
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    CreateFacturaDto _dto = new() { Lineas = new() { new() } };
    List<ClienteDto> _clientes = new();
    bool _guardando;
    bool _validado;

    decimal BaseImponible => _dto.Lineas.Sum(l => l.Subtotal);
    decimal ImporteIva    => Math.Round(BaseImponible * 0.21m, 2);
    decimal Total         => BaseImponible + ImporteIva;

    ClienteDto? _clienteSeleccionado => _clientes.FirstOrDefault(c => c.Id == _dto.ClienteId);

    protected override async Task OnInitializedAsync()
    {
        _clientes = await ClienteSvc.GetAllAsync(soloActivos: true);
    }

    void AgregarLinea()  => _dto.Lineas.Add(new());
    void EliminarLinea(int i) { if (_dto.Lineas.Count > 1) _dto.Lineas.RemoveAt(i); }

    async Task Guardar()
    {
        _validado = true;

        if (_dto.ClienteId == 0) return;
        if (_dto.Lineas.Count == 0) return;
        if (_dto.Lineas.Any(l => string.IsNullOrWhiteSpace(l.Descripcion) || l.Cantidad <= 0 || l.PrecioUnitario <= 0))
            return;

        _guardando = true;
        var (ok, id, msg) = await Svc.CreateAsync(_dto);
        _guardando = false;

        if (ok)
        {
            Notif.Success(msg);
            Nav.NavigateTo("/facturas");
        }
        else
        {
            Notif.Error(msg);
        }
    }
}
