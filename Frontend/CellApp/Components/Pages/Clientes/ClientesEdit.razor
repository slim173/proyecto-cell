@page "/clientes/{Id:int}/editar"
@rendermode InteractiveServer
@inject ClienteApiService Svc
@inject NavigationManager Nav
@inject NotificacionService Notif

<PageTitle>Editar cliente — CellShop</PageTitle>

<div class="page-header">
    <h4><i class="fas fa-user-edit me-2 text-primary"></i>Editar cliente</h4>
</div>

<LoadingSpinner Cargando="_cargando" />

@if (!_cargando && _dto != null)
{
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_dto.Nombre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Apellidos</label>
                            <input class="form-control" @bind="_dto.Apellidos" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                            <input class="form-control" type="email" @bind="_dto.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Teléfono</label>
                            <input class="form-control" @bind="_dto.Telefono" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">NIF / DNI</label>
                            <input class="form-control" @bind="_dto.Nif" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ciudad</label>
                            <input class="form-control" @bind="_dto.Ciudad" />
                        </div>
                        <div class="col-md-10">
                            <label class="form-label fw-semibold">Dirección</label>
                            <input class="form-control" @bind="_dto.Direccion" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold">C.P.</label>
                            <input class="form-control" @bind="_dto.CodigoPostal" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Observaciones</label>
                            <textarea class="form-control" @bind="_dto.Observaciones" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" @bind="_dto.Activo" id="chkActivo" />
                                <label class="form-check-label" for="chkActivo">Cliente activo</label>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger mt-3"><i class="fas fa-times-circle me-2"></i>@_error</div>
                    }

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a href="/clientes" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Cancelar
                        </a>
                        <button class="btn btn-primary" @onclick="Guardar" disabled="@_guardando">
                            @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="fas fa-save me-1"></i>Guardar cambios
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    UpdateClienteDto? _dto;
    bool _cargando = true;
    bool _guardando;
    string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var cliente = await Svc.GetByIdAsync(Id);
        if (cliente == null) { Nav.NavigateTo("/clientes"); return; }
        _dto = new UpdateClienteDto
        {
            Nombre = cliente.Nombre, Apellidos = cliente.Apellidos,
            Email = cliente.Email, Telefono = cliente.Telefono,
            Nif = cliente.Nif, Direccion = cliente.Direccion,
            Ciudad = cliente.Ciudad, CodigoPostal = cliente.CodigoPostal,
            Observaciones = cliente.Observaciones, Activo = cliente.Activo
        };
        _cargando = false;
    }

    async Task Guardar()
    {
        if (_dto == null) return;
        if (string.IsNullOrWhiteSpace(_dto.Nombre) || string.IsNullOrWhiteSpace(_dto.Email))
        {
            _error = "Nombre y email son obligatorios."; return;
        }
        _guardando = true; _error = string.Empty;
        try
        {
            var (ok, msg) = await Svc.UpdateAsync(Id, _dto);
            if (ok) { Notif.Success("Cliente actualizado."); Nav.NavigateTo("/clientes"); }
            else _error = msg;
        }
        catch (Exception ex) { _error = "Error al guardar: " + ex.Message; }
        finally { _guardando = false; }
    }
}
