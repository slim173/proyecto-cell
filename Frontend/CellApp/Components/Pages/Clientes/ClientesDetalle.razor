@page "/clientes/{Id:int}"
@rendermode InteractiveServer
@inject ClienteApiService ClienteSvc
@inject ReparacionApiService RepSvc
@inject VentaApiService VentaSvc
@inject NavigationManager Nav
@inject NotificacionService Notif

<PageTitle>Ficha de cliente — CellShop</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="fas fa-user me-2 text-primary"></i>Ficha del cliente</h4>
    <div class="d-flex gap-2">
        @if (!_cargando && _cliente != null)
        {
            <a href="/reparaciones/nueva?clienteId=@Id" class="btn btn-warning btn-sm">
                <i class="fas fa-tools me-1"></i>Nueva reparación
            </a>
            <a href="/ventas/nueva?clienteId=@Id" class="btn btn-success btn-sm">
                <i class="fas fa-cart-plus me-1"></i>Nueva venta
            </a>
            <button class="btn btn-outline-primary btn-sm" @onclick="() => _editando = !_editando">
                <i class="fas fa-edit me-1"></i>@(_editando ? "Cancelar" : "Editar")
            </button>
        }
        <a href="/clientes" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<LoadingSpinner Cargando="_cargando" />

@if (!_cargando && _cliente != null)
{
    <!-- ── Datos del cliente ── -->
    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center
                             @(_cliente.Activo ? "" : "bg-secondary bg-opacity-10")">
                    <span class="fw-semibold">
                        <i class="fas fa-id-card me-2 text-primary"></i>Datos personales
                    </span>
                    <span class="badge @(_cliente.Activo ? "bg-success" : "bg-secondary")">
                        @(_cliente.Activo ? "Activo" : "Inactivo")
                    </span>
                </div>
                <div class="card-body">
                    @if (!_editando)
                    {
                        <!-- Vista -->
                        <div class="text-center mb-3">
                            <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex
                                         align-items-center justify-content-center mb-2"
                                 style="width:72px;height:72px;font-size:2rem;">
                                <i class="fas fa-user text-primary"></i>
                            </div>
                            <div class="fw-bold fs-5">@_cliente.NombreCompleto</div>
                            @if (!string.IsNullOrEmpty(_cliente.Nif))
                            {
                                <small class="text-muted">NIF: @_cliente.Nif</small>
                            }
                        </div>
                        <ul class="list-unstyled mb-0 small">
                            @if (!string.IsNullOrEmpty(_cliente.Email))
                            {
                                <li class="mb-2">
                                    <i class="fas fa-envelope me-2 text-muted"></i>
                                    <a href="mailto:@_cliente.Email">@_cliente.Email</a>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(_cliente.Telefono))
                            {
                                <li class="mb-2">
                                    <i class="fas fa-phone me-2 text-muted"></i>
                                    <a href="tel:@_cliente.Telefono">@_cliente.Telefono</a>
                                    &nbsp;
                                    <a href="https://wa.me/@(LimpiarTel(_cliente.Telefono))" target="_blank"
                                       class="badge bg-success text-decoration-none">
                                        <i class="fab fa-whatsapp me-1"></i>WA
                                    </a>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(_cliente.Direccion))
                            {
                                <li class="mb-2">
                                    <i class="fas fa-map-marker-alt me-2 text-muted"></i>
                                    @_cliente.Direccion
                                    @if (!string.IsNullOrEmpty(_cliente.CodigoPostal) || !string.IsNullOrEmpty(_cliente.Ciudad))
                                    {
                                        <span>, @_cliente.CodigoPostal @_cliente.Ciudad</span>
                                    }
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(_cliente.Observaciones))
                            {
                                <li class="mt-3 p-2 bg-light rounded">
                                    <i class="fas fa-sticky-note me-2 text-muted"></i>@_cliente.Observaciones
                                </li>
                            }
                        </ul>
                        <div class="text-muted small mt-3">
                            <i class="fas fa-calendar me-1"></i>
                            Cliente desde @_cliente.FechaCreacion.ToString("dd/MM/yyyy")
                        </div>
                    }
                    else
                    {
                        <!-- Edición inline -->
                        <div class="row g-2">
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Nombre <span class="text-danger">*</span></label>
                                <input class="form-control form-control-sm" @bind="_editDto.Nombre" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Apellidos</label>
                                <input class="form-control form-control-sm" @bind="_editDto.Apellidos" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Email <span class="text-danger">*</span></label>
                                <input class="form-control form-control-sm" type="email" @bind="_editDto.Email" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Teléfono</label>
                                <input class="form-control form-control-sm" @bind="_editDto.Telefono" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">NIF/DNI</label>
                                <input class="form-control form-control-sm" @bind="_editDto.Nif" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">C.P.</label>
                                <input class="form-control form-control-sm" @bind="_editDto.CodigoPostal" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Ciudad</label>
                                <input class="form-control form-control-sm" @bind="_editDto.Ciudad" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Dirección</label>
                                <input class="form-control form-control-sm" @bind="_editDto.Direccion" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Observaciones</label>
                                <textarea class="form-control form-control-sm" rows="2"
                                          @bind="_editDto.Observaciones"></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox"
                                           @bind="_editDto.Activo" id="chkActivo" />
                                    <label class="form-check-label small" for="chkActivo">Activo</label>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_errorEdit))
                        {
                            <div class="alert alert-danger py-1 small mt-2">@_errorEdit</div>
                        }
                        <div class="d-grid mt-3">
                            <button class="btn btn-primary btn-sm" @onclick="Guardar" disabled="@_guardando">
                                @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="fas fa-save me-1"></i>Guardar cambios
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ── Estadísticas ── -->
        <div class="col-lg-8">
            <div class="row g-3 mb-3">
                <div class="col-sm-3">
                    <div class="card shadow-sm text-center border-primary border-opacity-25">
                        <div class="card-body py-3">
                            <div class="fs-2 fw-bold text-primary">@_reparaciones.Count</div>
                            <small class="text-muted">Reparaciones</small>
                        </div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="card shadow-sm text-center border-success border-opacity-25">
                        <div class="card-body py-3">
                            <div class="fs-2 fw-bold text-success">@_reparaciones.Count(r => r.Estado == "entregado")</div>
                            <small class="text-muted">Entregadas</small>
                        </div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="card shadow-sm text-center border-warning border-opacity-25">
                        <div class="card-body py-3">
                            @{ var abiertas = _reparaciones.Count(r => r.Estado != "entregado" && r.Estado != "no_reparable"); }
                            <div class="fs-2 fw-bold text-warning">@abiertas</div>
                            <small class="text-muted">En curso</small>
                        </div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="card shadow-sm text-center border-info border-opacity-25">
                        <div class="card-body py-3">
                            @{ var totalGastado = _reparaciones.Where(r => r.Total.HasValue).Sum(r => r.Total!.Value)
                                                + _ventas.Sum(v => v.Total); }
                            <div class="fs-4 fw-bold text-info">@totalGastado.ToString("N2") €</div>
                            <small class="text-muted">Total gastado</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reparaciones en curso -->
            @{ var enCurso = _reparaciones.Where(r => r.Estado != "entregado" && r.Estado != "no_reparable").ToList(); }
            @if (enCurso.Any())
            {
                <div class="alert alert-warning d-flex align-items-start gap-2 py-2">
                    <i class="fas fa-tools mt-1"></i>
                    <div>
                        <strong>@enCurso.Count reparación(es) activa(s):</strong>
                        @foreach (var r in enCurso)
                        {
                            <a href="/reparaciones/@r.Id" class="ms-2 badge bg-warning text-dark text-decoration-none">
                                @r.NumeroOrden — @r.Dispositivo @r.Marca @r.Modelo (@EstadoLabel(r.Estado))
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Últimas compras / ventas -->
            @if (_ventas.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-shopping-cart me-2 text-success"></i>Últimas compras (@_ventas.Count)</span>
                        <a href="/ventas/nueva?clienteId=@Id" class="btn btn-sm btn-outline-success">
                            <i class="fas fa-plus me-1"></i>Nueva venta
                        </a>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>N° Venta</th>
                                    <th>Fecha</th>
                                    <th>Pago</th>
                                    <th class="text-end">Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in _ventas.Take(5))
                                {
                                    <tr>
                                        <td><strong>@v.NumeroVenta</strong></td>
                                        <td class="small text-muted">@v.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><small>@(v.MetodoPago ?? "—")</small></td>
                                        <td class="text-end fw-semibold">@v.Total.ToString("N2") €</td>
                                        <td>
                                            <a href="/ventas/@v.Id" class="btn btn-sm btn-outline-secondary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ── Historial de reparaciones ── -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-tools me-2 text-primary"></i>Historial de reparaciones (@_reparaciones.Count)</span>
            <a href="/reparaciones/nueva?clienteId=@Id" class="btn btn-sm btn-outline-warning">
                <i class="fas fa-plus me-1"></i>Nueva reparación
            </a>
        </div>
        @if (!_reparaciones.Any())
        {
            <div class="card-body text-center text-muted py-4">
                <i class="fas fa-tools fa-2x mb-2 d-block opacity-25"></i>
                Este cliente aún no tiene reparaciones registradas.
            </div>
        }
        else
        {
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° Orden</th>
                            <th>Dispositivo</th>
                            <th>Falla</th>
                            <th>Estado</th>
                            <th>Prioridad</th>
                            <th>Recepción</th>
                            <th>Entrega</th>
                            <th class="text-end">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _reparaciones.OrderByDescending(x => x.FechaRecepcion))
                        {
                            <tr>
                                <td><strong>@r.NumeroOrden</strong></td>
                                <td>
                                    <div>@r.Dispositivo</div>
                                    @if (!string.IsNullOrEmpty(r.Marca) || !string.IsNullOrEmpty(r.Modelo))
                                    {
                                        <small class="text-muted">@r.Marca @r.Modelo</small>
                                    }
                                    @if (!string.IsNullOrEmpty(r.Imei))
                                    {
                                        <div class="font-monospace" style="font-size:0.7rem;color:#888;">@r.Imei</div>
                                    }
                                </td>
                                <td style="max-width:200px;">
                                    <small class="text-truncate d-block" title="@r.DescripcionFalla">
                                        @(r.DescripcionFalla.Length > 50 ? r.DescripcionFalla[..47] + "…" : r.DescripcionFalla)
                                    </small>
                                    @if (!string.IsNullOrEmpty(r.Solucion))
                                    {
                                        <small class="text-success d-block" title="@r.Solucion">
                                            <i class="fas fa-check-circle me-1"></i>
                                            @(r.Solucion.Length > 40 ? r.Solucion[..37] + "…" : r.Solucion)
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-@EstadoColor(r.Estado)">@EstadoLabel(r.Estado)</span>
                                </td>
                                <td>
                                    <span class="badge bg-@PrioridadColor(r.Prioridad) bg-opacity-75">@r.Prioridad</span>
                                </td>
                                <td><small>@r.FechaRecepcion.ToString("dd/MM/yyyy")</small></td>
                                <td>
                                    @if (r.FechaEntregaReal.HasValue)
                                    {
                                        <small class="text-success">@r.FechaEntregaReal.Value.ToString("dd/MM/yyyy")</small>
                                    }
                                    else if (r.FechaEstimadaEntrega.HasValue)
                                    {
                                        <small class="@(r.FechaEstimadaEntrega < DateTime.Now && r.Estado != "entregado" ? "text-danger fw-semibold" : "text-muted")">
                                            ~@r.FechaEstimadaEntrega.Value.ToString("dd/MM/yyyy")
                                        </small>
                                    }
                                    else { <small class="text-muted">—</small> }
                                </td>
                                <td class="text-end">
                                    @if (r.Total.HasValue)
                                    {
                                        <strong class="text-success">@r.Total.Value.ToString("N2") €</strong>
                                    }
                                    else if (r.PrecioEstimado.HasValue)
                                    {
                                        <span class="text-muted small">~@r.PrecioEstimado.Value.ToString("N2") €</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    <a href="/reparaciones/@r.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    ClienteDto?          _cliente;
    List<ReparacionDto>  _reparaciones = new();
    List<VentaDto>       _ventas       = new();
    bool   _cargando = true;
    bool   _editando;
    bool   _guardando;
    string _errorEdit = string.Empty;
    UpdateClienteDto _editDto = new();

    protected override async Task OnInitializedAsync()
    {
        var t1 = ClienteSvc.GetByIdAsync(Id);
        var t2 = RepSvc.GetAllAsync();
        var t3 = VentaSvc.GetAllAsync();
        await Task.WhenAll(t1, t2, t3);

        _cliente = t1.Result;
        if (_cliente == null) { Nav.NavigateTo("/clientes"); return; }

        _reparaciones = t2.Result.Where(r => r.ClienteId == Id).ToList();
        _ventas       = t3.Result.Where(v => v.ClienteId == Id)
                                 .OrderByDescending(v => v.Fecha).ToList();

        IniciarEdicion();
        _cargando = false;
    }

    void IniciarEdicion()
    {
        if (_cliente == null) return;
        _editDto = new UpdateClienteDto
        {
            Nombre        = _cliente.Nombre,
            Apellidos     = _cliente.Apellidos,
            Email         = _cliente.Email,
            Telefono      = _cliente.Telefono,
            Nif           = _cliente.Nif,
            Ciudad        = _cliente.Ciudad,
            Direccion     = _cliente.Direccion,
            CodigoPostal  = _cliente.CodigoPostal,
            Observaciones = _cliente.Observaciones,
            Activo        = _cliente.Activo,
        };
        _errorEdit = string.Empty;
    }

    async Task Guardar()
    {
        _errorEdit = string.Empty;
        if (string.IsNullOrWhiteSpace(_editDto.Nombre)) { _errorEdit = "El nombre es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(_editDto.Email))  { _errorEdit = "El email es obligatorio."; return; }

        _guardando = true;
        var (ok, msg) = await ClienteSvc.UpdateAsync(Id, _editDto);
        _guardando = false;

        if (ok)
        {
            Notif.Success("Cliente actualizado correctamente.");
            _cliente = await ClienteSvc.GetByIdAsync(Id);
            _editando = false;
        }
        else _errorEdit = msg;
    }

    static string LimpiarTel(string? tel) =>
        string.IsNullOrEmpty(tel) ? "" :
        new string(tel.Where(c => char.IsDigit(c) || c == '+').ToArray()).TrimStart('+');

    static string EstadoLabel(string e) => e switch
    {
        "recibido"      => "Recibido",
        "diagnosticado" => "Diagnosticado",
        "en_reparacion" => "En reparación",
        "reparado"      => "Reparado",
        "entregado"     => "Entregado",
        "no_reparable"  => "No reparable",
        _               => e
    };

    static string EstadoColor(string e) => e switch
    {
        "recibido"      => "secondary",
        "diagnosticado" => "info",
        "en_reparacion" => "warning",
        "reparado"      => "primary",
        "entregado"     => "success",
        "no_reparable"  => "danger",
        _               => "secondary"
    };

    static string PrioridadColor(string p) => p switch
    {
        "urgente" => "danger",
        "alta"    => "warning",
        "normal"  => "primary",
        "baja"    => "secondary",
        _         => "secondary"
    };
}
