@page "/clientes/nuevo"
@rendermode InteractiveServer
@inject ClienteApiService Svc
@inject NavigationManager Nav
@inject NotificacionService Notif

<PageTitle>Nuevo cliente — CellShop</PageTitle>

<div class="page-header">
    <h4><i class="fas fa-user-plus me-2 text-primary"></i>Nuevo cliente</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <EditForm Model="_dto" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_dto.Nombre" placeholder="Nombre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Apellidos</label>
                            <InputText class="form-control" @bind-Value="_dto.Apellidos" placeholder="Apellidos" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                            <InputText class="form-control" type="email" @bind-Value="_dto.Email" placeholder="email@ejemplo.es" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Teléfono</label>
                            <InputText class="form-control" @bind-Value="_dto.Telefono" placeholder="+34 600 000 000" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">NIF / DNI</label>
                            <InputText class="form-control" @bind-Value="_dto.Nif" placeholder="12345678A" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ciudad</label>
                            <InputText class="form-control" @bind-Value="_dto.Ciudad" placeholder="Madrid" />
                        </div>
                        <div class="col-md-10">
                            <label class="form-label fw-semibold">Dirección</label>
                            <InputText class="form-control" @bind-Value="_dto.Direccion" placeholder="Calle, número, piso..." />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold">C.P.</label>
                            <InputText class="form-control" @bind-Value="_dto.CodigoPostal" placeholder="28001" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Observaciones</label>
                            <InputTextArea class="form-control" @bind-Value="_dto.Observaciones" rows="2" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger mt-3"><i class="fas fa-times-circle me-2"></i>@_error</div>
                    }

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a href="/clientes" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary" disabled="@_guardando">
                            @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="fas fa-save me-1"></i>Guardar cliente
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    CreateClienteDto _dto = new();
    bool _guardando;
    string _error = string.Empty;

    async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_dto.Nombre) || string.IsNullOrWhiteSpace(_dto.Email))
        {
            _error = "Nombre y email son obligatorios."; return;
        }
        _guardando = true; _error = string.Empty;
        try
        {
            var (ok, msg) = await Svc.CreateAsync(_dto);
            if (ok) { Notif.Success("Cliente creado correctamente."); Nav.NavigateTo("/clientes"); }
            else _error = msg;
        }
        catch (Exception ex) { _error = "Error al guardar: " + ex.Message; }
        finally { _guardando = false; }
    }
}
