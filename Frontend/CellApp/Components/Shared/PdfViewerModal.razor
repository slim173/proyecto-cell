@inject IJSRuntime JS

@* Abre el PDF en nueva pestaña vía JS en cuanto recibe la URL *@

@code {
    private string _lastUrl = string.Empty;

    [Parameter] public string        PdfUrl  { get; set; } = string.Empty;
    [Parameter] public string        Titulo  { get; set; } = "Vista previa";
    [Parameter] public EventCallback OnClose { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(PdfUrl) && PdfUrl != _lastUrl)
        {
            _lastUrl = PdfUrl;
            await JS.InvokeVoidAsync("open", PdfUrl, "_blank");
            await OnClose.InvokeAsync();
        }
    }
}
